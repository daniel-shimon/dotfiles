# Secrets template. Copy to secrets.fish and fill real values.
#   cp secrets.fish.example secrets.fish
# secrets.fish is gitignored — NEVER commit real secrets.
# Fish auto-loads everything in conf.d/ at startup.

set -gx TEAMCITY_ACCESS_TOKEN ...
